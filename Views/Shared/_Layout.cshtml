@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Identity
@using MusicAndMind2.Models
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory Factory
@{
    var L = Factory.Create("SharedResource", "MusicAndMind2");

    // 🧮 Взимаме броя на продуктите от СЕСИЯТА (както в CartController)
    int cartCount = 0;
    string sessionKey = User.Identity.IsAuthenticated
        ? $"CartItems_{UserManager.GetUserName(User)}"
        : "CartItems_Guest";

    var cartJson = Context.Session.GetString(sessionKey);
    if (!string.IsNullOrEmpty(cartJson))
    {
        var cartList = Newtonsoft.Json.JsonConvert
            .DeserializeObject<List<MusicAndMind2.Models.Product>>(cartJson);

        cartCount = cartList?.Count ?? 0;
    }
}


<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @L["AppTitle"]</title>
    <link rel="stylesheet" href="/css/site.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>
<body class="theme-dark">
    <header class="navbar">
        <div class="nav-left">
            <a class="brand" href="/">Music<span>&</span>Mind</a>

            <a href="/Shop" class="shop-link" title="Магазин">
                Магазин
            </a>

            <!-- 🛒 Количка -->
            <a href="/Cart" class="cart-icon" id="cart-icon" title="Кошница">
                🛒
                <span id="cart-count" class="cart-badge">@cartCount</span>
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="admin-dropdown">
                    <button type="button" class="admin-link">Админ ▾</button>
                    <div class="admin-menu">
                        <a href="/Admin/ProductList">🛒 Управление на продукти</a>
                        <a href="/Admin">👥 Регистрирани акаунти</a>
                    </div>
                </div>
            }

            <nav class="menu">
                <a href="/">@L["Начало"]</a>
                <a href="/Home/Focus">@L["Фокус"]</a>
                <a href="/Home/Science">@L["Наука"]</a>
                <a href="/Home/About">@L["За нас"]</a>
                <a href="/Home/Contact">@L["Контакти"]</a>
            </nav>
        </div>

        <div class="nav-right">
            @if (SignInManager.IsSignedIn(User))
            {
                <a href="/Focus/MyTracks" class="auth-link">🎵 Моите честоти</a>
                <span class="user-info">👤 @UserManager.GetUserName(User)</span>
                <form asp-controller="Auth" asp-action="Logout" method="post" class="logout-form">
                    <button type="submit" class="btn-logout">@L["Изход"]</button>
                </form>
            }
            else
            {
                <a href="/Auth/Login" class="auth-link">@L["Вход"]</a>
                <a href="/Auth/Register" class="auth-link">@L["Регистрация"]</a>
            }
        </div>
    </header>

    <main class="container">@RenderBody()</main>

    <!-- 🌙 Нов футър -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-section contact-info">
                <h4>Свържете се с нас</h4>
                <p>📞 <a href="tel:0896973940">0896 973 940</a></p>
                <p>✉️ <a href="mailto:contact@musicandmind.bg">contact@musicandmind.bg</a></p>
            </div>

            <div class="footer-section quick-links">
                <h4>Навигация</h4>
                <a href="/Home/About">За нас</a>
                <a href="/Home/Privacy">Политика за поверителност</a>
                <a href="/Home/Terms">Условия за ползване</a>
            </div>

            <div class="footer-section social">
                <h4>Последвайте ни</h4>
                <div class="social-icons">
                    <a href="https://facebook.com" target="_blank" title="Facebook">🌐</a>
                    <a href="https://instagram.com" target="_blank" title="Instagram">📸</a>
                    <a href="https://youtube.com" target="_blank" title="YouTube">🎵</a>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <p>© @DateTime.Now.Year Music & Mind • Създадено с любов и хармония 🌸</p>
        </div>
    </footer>

    <script src="/js/site.js"></script>

    <!-- Sakura petals -->
    @for (int i = 0; i < 12; i++)
    {
        <div class="sakura-petal"></div>
    }

    <style>
        /* 🌸 Навигация */
        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 2rem;
            position: relative;
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 2rem;
        }

        .brand {
            font-weight: 800;
            font-size: 1.1rem;
            color: var(--text-color, #fff);
            text-decoration: none;
        }

        .menu {
            display: flex;
            gap: 1.5rem;
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 1rem;
            position: absolute;
            right: 9rem;
            top: 50%;
            transform: translateY(-50%);
        }

        .auth-link, .btn-logout {
            font-weight: 500;
            text-decoration: none;
            color: var(--text-color, #fff);
            transition: opacity 0.2s ease;
        }

            .auth-link:hover, .btn-logout:hover {
                opacity: 0.7;
            }

        .user-info {
            opacity: 0.8;
            font-size: 0.9rem;
        }

        .admin-link {
            margin-left: 1rem;
            font-weight: 600;
            text-decoration: none;
            color: var(--text-color, #fff);
            background: rgba(255, 255, 255, 0.08);
            padding: 0.4rem 0.9rem;
            border-radius: 10px;
            transition: all 0.25s ease;
            box-shadow: 0 0 10px rgba(255,255,255,0.05);
            border: none;
            cursor: pointer;
        }

            .admin-link:hover {
                background: var(--accent-color, #ff69b4);
                color: #fff;
                box-shadow: 0 0 15px rgba(255, 105, 180, 0.4);
            }

        .shop-link {
            margin-left: 1rem;
            font-size: 1.3rem;
            text-decoration: none;
            color: var(--text-color, #fff);
            transition: transform 0.2s ease, color 0.2s ease;
            display: inline-flex;
            align-items: center;
        }

            .shop-link:hover {
                transform: scale(1.1);
                color: var(--accent-color, #ff69b4);
            }

        /* 🛒 Количка */
        .cart-icon {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            color: white;
            text-decoration: none;
            transition: transform 0.2s ease, color 0.2s ease;
            width: 36px;
            height: 36px;
        }

            .cart-icon:hover {
                transform: scale(1.08);
                color: #ff8ecf;
            }

        .cart-badge {
            position: absolute;
            top: -6px;
            right: -10px;
            background-color: #ff69b4;
            color: white;
            border-radius: 50%;
            font-size: 0.7rem;
            line-height: 1.2;
            padding: 2px 6px;
            font-weight: 700;
            min-width: 18px;
            min-height: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 6px rgba(255, 105, 180, 0.5);
        }

        /* 🔽 Admin dropdown */
        .admin-dropdown {
            position: relative;
            display: inline-block;
        }

        .admin-menu {
            display: none;
            position: absolute;
            top: 120%;
            left: 0;
            background: rgba(0,0,0,0.7);
            padding: 0.7rem 0;
            border-radius: 10px;
            min-width: 220px;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
            z-index: 999;
            backdrop-filter: blur(6px);
        }

            .admin-menu a {
                display: block;
                padding: 0.6rem 1rem;
                color: #fff;
                text-decoration: none;
                font-size: 0.9rem;
                transition: background 0.2s ease, color 0.2s ease;
            }

                .admin-menu a:hover {
                    background: rgba(255, 105, 180, 0.25);
                    color: #ffb8dd;
                }

        /* показваме менюто когато контейнерът има клас open */
        .admin-dropdown.open .admin-menu {
            display: block;
        }

        /* 🌑 Футър */
        .footer {
            background: rgba(255, 255, 255, 0.03);
            padding: 2rem 1rem 1rem;
            text-align: center;
            color: #fff;
            font-family: 'Inter', sans-serif;
            border-top: 1px solid rgba(255,255,255,0.1);
            margin-top: 3rem;
        }

        .footer-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 3rem;
            margin-bottom: 1.5rem;
        }

        .footer-section h4 {
            color: #ff69b4;
            margin-bottom: 0.8rem;
            font-weight: 700;
        }

        .footer-section a {
            display: block;
            color: #fff;
            text-decoration: none;
            margin: 0.3rem 0;
            opacity: 0.85;
            transition: 0.3s ease;
        }

            .footer-section a:hover {
                color: #ff85c2;
                transform: translateX(3px);
            }

        .social-icons a {
            display: inline-block;
            margin: 0 0.5rem;
            font-size: 1.3rem;
            transition: transform 0.3s ease;
        }

            .social-icons a:hover {
                transform: scale(1.3);
            }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 1rem;
            font-size: 0.9rem;
            opacity: 0.8;
        }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const badge = document.getElementById("cart-count");
            if (badge) {
                badge.classList.add("animate");
                setTimeout(() => badge.classList.remove("animate"), 400);
            }

            // 🔽 Админ dropdown на клик
            const adminDropdown = document.querySelector('.admin-dropdown');
            const adminButton = adminDropdown?.querySelector('.admin-link');

            if (adminDropdown && adminButton) {
                adminButton.addEventListener('click', (e) => {
                    e.stopPropagation(); // да не затвори веднага
                    adminDropdown.classList.toggle('open');
                });

                // скриване при клик извън менюто
                document.addEventListener('click', (e) => {
                    if (!adminDropdown.contains(e.target)) {
                        adminDropdown.classList.remove('open');
                    }
                });
            }
        });
    </script>

    @RenderSection("Scripts", required: false)

    <!-- 🤖 AI Chat Button -->
    <div id="ai-button" onclick="toggleAI()">💬</div>

    <!-- 💗 AI Chat Box -->
    <div id="ai-chat">
        <div class="ai-header">Music & Mind Асистент 🌸</div>
        <div id="ai-messages" class="ai-messages"></div>

        <div class="ai-input-box">
            <input id="ai-input" placeholder="Попитай за продукт, спокойствие или концентрация..." />
            <button onclick="sendAI()">➤</button>
        </div>
    </div>

    <style>
        #ai-button {
            position: fixed;
            bottom: 25px;
            right: 25px;
            width: 60px;
            height: 60px;
            background: #ff69b4;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 0 15px rgba(255,105,180,0.6);
            z-index: 9999;
            transition: 0.3s;
        }

            #ai-button:hover {
                transform: scale(1.1);
                background: #ff85c0;
            }

        #ai-chat {
            position: fixed;
            bottom: 100px;
            right: 25px;
            width: 300px;
            background: rgba(0,0,0,0.8);
            border-radius: 15px;
            display: none;
            flex-direction: column;
            overflow: hidden;
            backdrop-filter: blur(10px);
            box-shadow: 0 0 20px rgba(255,105,180,0.3);
            z-index: 9999;
        }

        .ai-header {
            background: #ff69b4;
            padding: 10px;
            font-weight: bold;
            text-align: center;
        }

        .ai-messages {
            padding: 10px;
            height: 250px;
            overflow-y: auto;
            font-size: 0.9rem;
        }

        .ai-input-box {
            display: flex;
        }

            .ai-input-box input {
                flex: 1;
                border: none;
                padding: 10px;
                outline: none;
            }

            .ai-input-box button {
                background: #ff69b4;
                border: none;
                color: white;
                padding: 10px;
                cursor: pointer;
            }
    </style>

    <script>
                function toggleAI() {
            const chat = document.getElementById("ai-chat");
            const messages = document.getElementById("ai-messages");

            const isOpening = chat.style.display !== "flex";
            chat.style.display = isOpening ? "flex" : "none";

            if (isOpening && messages.innerHTML.trim() === "") {
                addMessage("Асистент", "Здравей и добре дошъл в Music & Mind 🌸 Аз съм тук, за да ти помогна да откриеш най-подходящите продукти за спокойствие, фокус и хармония.");
            }
        }

        function sendAI() {
            const input = document.getElementById("ai-input");
            const msg = input.value;

            if (!msg) return;

            addMessage("Ти", msg);
            input.value = "";

            fetch("/api/ai/ask", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(msg)
            })
            .then(r => r.text())
            .then(res => {
                addMessage("AI", res);
            });
        }

        function addMessage(sender, text) {
            const box = document.getElementById("ai-messages");
            box.innerHTML += `<div><b>${sender}:</b> ${text}</div>`;
            box.scrollTop = box.scrollHeight;
        }
    </script>
</body>
</html>
