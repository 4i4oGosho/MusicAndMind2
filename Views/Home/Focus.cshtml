@using MusicAndMind2.Controllers   @* за FocusTrackDefinition ако го ползваш тук в бъдеще *@
@{
    ViewData["Title"] = "Концентрация";
}

<section class="prose focus fade-in">
    <h1>Концентрация и продуктивност</h1>
    <p class="fade-step">
        Звукът може да направи ума <strong>по-ясен, подреден и спокоен</strong>.
        Мозъчните ритми могат да се насочат към състояния,
        които помагат на вниманието и мисленето.
    </p>

    <figure class="fade-step tilt">
        <!-- ✅ INLINE SVG BRAIN -->
        <svg width="900" height="600" viewBox="0 0 900 600" xmlns="http://www.w3.org/2000/svg">
            <rect width="900" height="600" fill="#0b0b0b" />
            <g stroke="#ffffff" stroke-width="2" opacity="0.7">
                <circle cx="450" cy="300" r="140" fill="none" />
                <circle cx="450" cy="300" r="180" fill="none" opacity="0.3" />
            </g>
            <g stroke="#777" stroke-width="2">
                <line x1="350" y1="250" x2="430" y2="320" />
                <line x1="430" y1="320" x2="500" y2="260" />
                <line x1="500" y1="260" x2="540" y2="330" />
                <line x1="430" y1="320" x2="390" y2="360" />
                <line x1="390" y1="360" x2="470" y2="380" />
            </g>
            <g fill="#ffffff">
                <circle cx="350" cy="250" r="8" />
                <circle cx="430" cy="320" r="8" />
                <circle cx="500" cy="260" r="8" />
                <circle cx="540" cy="330" r="8" />
                <circle cx="390" cy="360" r="8" />
                <circle cx="470" cy="380" r="8" />
            </g>
        </svg>
        <figcaption>Активиране на префронталната кора — центърът на вземане на решения</figcaption>
    </figure>

    <h2>Звукови пътеки за фокус</h2>
    <p>
        Тези аудио вълни са проектирани да поддържат <strong>дълбока концентрация</strong>,
        без допълнителен стрес или напрежение.
    </p>

    @if (TempData["FocusMessage"] != null)
    {
        <div class="alert-soft">
            @TempData["FocusMessage"]
        </div>
    }

    <div class="grid fade-step">
        @* Alpha *@
        <article class="card fade-step">
            <div class="thumb"><img src="/images/wave-thumb.png" alt="Alpha waves"></div>
            <div class="card-body">
                <h3>Alpha Flow (10 Hz AM)</h3>
                <p>Спокоен фокус — идеален за учене и четене.</p>
                <div class="controls">
                    <button class="btn play" data-src="/audio/alpha_am_200_10.wav">▶</button>
                    <input class="vol" type="range" min="0" max="1" step="0.01" value="0.3" />
                    <span class="tag">Спокоен</span>
                </div>

                @if (User.Identity!.IsAuthenticated)
                {
                    <form asp-controller="Focus" asp-action="Save" method="post" class="focus-actions">
                        <input type="hidden" name="trackKey" value="alpha" />
                        <button type="submit" class="btn-fancy small">Запази в профила</button>
                        <a href="/audio/alpha_am_200_10.wav" download class="btn-ghost small">Изтегли</a>
                    </form>
                }
                else
                {
                    <p class="hint">🔒 Влез, за да запазиш честотата и да я намираш по-късно.</p>
                    <a href="/Auth/Login" class="btn-fancy small">Вход</a>
                }
            </div>
        </article>

        @* Gamma *@
        <article class="card fade-step">
            <div class="thumb"><img src="/images/wave-gamma.png" alt="Gamma waves"></div>
            <div class="card-body">
                <h3>Gamma Spark (40 Hz AM)</h3>
                <p>Дълбока работа — логика, анализ, памет.</p>
                <div class="controls">
                    <button class="btn play" data-src="/audio/gamma_am_400_40.wav">▶</button>
                    <input class="vol" type="range" min="0" max="1" step="0.01" value="0.25" />
                    <span class="tag">Deep Work</span>
                </div>

                @if (User.Identity!.IsAuthenticated)
                {
                    <form asp-controller="Focus" asp-action="Save" method="post" class="focus-actions">
                        <input type="hidden" name="trackKey" value="gamma" />
                        <button type="submit" class="btn-fancy small">Запази в профила</button>
                        <a href="/audio/gamma_am_400_40.wav" download class="btn-ghost small">Изтегли</a>
                    </form>
                }
            </div>
        </article>

        @* 528 *@
        <article class="card fade-step">
            <div class="thumb"><img src="/images/wave-528.jpg" alt="528 Hz"></div>
            <div class="card-body">
                <h3>528 Hz Tone</h3>
                <p>Емоционален баланс — спокойствие и дишане.</p>
                <div class="controls">
                    <button class="btn play" data-src="/audio/528hz.wav">▶</button>
                    <input class="vol" type="range" min="0" max="1" step="0.01" value="0.2" />
                    <span class="tag">Баланс</span>
                </div>

                @if (User.Identity!.IsAuthenticated)
                {
                    <form asp-controller="Focus" asp-action="Save" method="post" class="focus-actions">
                        <input type="hidden" name="trackKey" value="hz528" />
                        <button type="submit" class="btn-fancy small">Запази в профила</button>
                        <a href="/audio/528hz.wav" download class="btn-ghost small">Изтегли</a>
                    </form>
                }
            </div>
        </article>

        @* 432 *@
        <article class="card fade-step">
            <div class="thumb"><img src="/images/wave-432.jpg" alt="432 Hz"></div>
            <div class="card-body">
                <h3>A=432 Hz Tone</h3>
                <p>Органична хармония — идеална за спокойни задачи.</p>
                <div class="controls">
                    <button class="btn play" data-src="/audio/432hz.wav">▶</button>
                    <input class="vol" type="range" min="0" max="1" step="0.01" value="0.2" />
                    <span class="tag">Хармония</span>
                </div>

                @if (User.Identity!.IsAuthenticated)
                {
                    <form asp-controller="Focus" asp-action="Save" method="post" class="focus-actions">
                        <input type="hidden" name="trackKey" value="hz432" />
                        <button type="submit" class="btn-fancy small">Запази в профила</button>
                        <a href="/audio/432hz.wav" download class="btn-ghost small">Изтегли</a>
                    </form>
                }
            </div>
        </article>
    </div>

    @* 852 Hz *@
    <article class="card fade-step">
        <div class="thumb"><img src="/images/wave-852hz.jpg" alt="852 Hz"></div>
        <div class="card-body">
            <h3>852 Hz Tone</h3>
            <p>Интуиция и вътрешна яснота — възстановява връзката със собственото Аз.</p>
            <div class="controls">
                <button class="btn play" data-src="/audio/852hz.mp3">▶</button>
                <input class="vol" type="range" min="0" max="1" step="0.01" value="0.25" />
                <span class="tag">Интуиция</span>
            </div>

            @if (User.Identity!.IsAuthenticated)
            {
                <form asp-controller="Focus" asp-action="Save" method="post" class="focus-actions">
                    <input type="hidden" name="trackKey" value="hz852" />
                    <button type="submit" class="btn-fancy small">Запази в профила</button>
                    <a href="/audio/852hz.mp3" download class="btn-ghost small">Изтегли</a>
                </form>
            }
        </div>
    </article>

    @* 963 Hz *@
    <article class="card fade-step">
        <div class="thumb"><img src="/images/wave-963.jpg" alt="963 Hz"></div>
        <div class="card-body">
            <h3>963 Hz Tone</h3>
            <p>Съзнателност и хармония — честота на „божествената връзка“ и вътрешния мир.</p>
            <div class="controls">
                <button class="btn play" data-src="/audio/963hz.mp3">▶</button>
                <input class="vol" type="range" min="0" max="1" step="0.01" value="0.25" />
                <span class="tag">Просветление</span>
            </div>

            @if (User.Identity!.IsAuthenticated)
            {
                <form asp-controller="Focus" asp-action="Save" method="post" class="focus-actions">
                    <input type="hidden" name="trackKey" value="hz963" />
                    <button type="submit" class="btn-fancy small">Запази в профила</button>
                    <a href="/audio/963hz.mp3" download class="btn-ghost small">Изтегли</a>
                </form>
            }
        </div>
    </article>

    <h2>Енергията следва вниманието</h2>
    <p class="fade-step">
        Без напрежение — просто стабилност и чисто присъствие.
    </p>

    <figure class="fade-step">
        <img src="/images/energy-focus.png" alt="Концентрация и фокус" />
        <figcaption>Стресът пада. Концентрацията расте.</figcaption>
    </figure>
</section>

<style>
    .focus-actions {
        margin-top: 0.8rem;
        display: flex;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    .btn-fancy.small,
    .btn-ghost.small {
        padding: 0.35rem 0.9rem;
        font-size: 0.8rem;
    }

    .alert-soft {
        margin: 1rem 0;
        padding: 0.75rem 1rem;
        border-radius: 12px;
        background: rgba(255, 105, 180, 0.12);
        border: 1px solid rgba(255, 105, 180, 0.4);
        font-size: 0.9rem;
    }

    .hint {
        font-size: 0.8rem;
        opacity: 0.7;
        margin-top: 0.5rem;
    }
</style>
