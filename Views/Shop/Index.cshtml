@model IEnumerable<MusicAndMind2.Models.Product>

@{
    ViewData["Title"] = "Магазин";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var currentSearch = ViewBag.CurrentSearch as string ?? "";
    var currentCategory = ViewBag.CurrentCategory as string ?? "";
    var currentSort = ViewBag.CurrentSort as string ?? "";
}

<div class="shop-container">
    <h1 class="shop-title">🕉 Магазин на Music & Mind 🕉</h1>
    <p class="shop-subtitle">Инструменти, които хармонизират ума чрез звук и вибрация.</p>

    <div id="cartMessage" class="cart-message" style="display:none;">
        ✅ Продуктът е добавен в кошницата!
    </div>

    <form method="get" asp-controller="Shop" asp-action="Index" class="shop-filters">
        <div class="search-box">
            <input type="text"
                   name="searchTerm"
                   value="@currentSearch"
                   placeholder="Търси по име, описание или категория..."
                   class="search-input" />

            <button type="submit" class="search-btn">Търси</button>
        </div>

        <div class="filter-box">
            <select name="category" class="category-select">
                <option value="">Всички категории</option>
                @foreach (var category in categories)
                {
                    if (currentCategory == category)
                    {
                        <option value="@category" selected>@category</option>
                    }
                    else
                    {
                        <option value="@category">@category</option>
                    }
                }
            </select>

            <select name="sortOrder" class="category-select">
                <option value="">Подреди по: Най-нови</option>
                @if (currentSort == "price_asc")
                {
                    <option value="price_asc" selected>Цена: ниска към висока</option>
                }
                else
                {
                    <option value="price_asc">Цена: ниска към висока</option>
                }

                @if (currentSort == "price_desc")
                {
                    <option value="price_desc" selected>Цена: висока към ниска</option>
                }
                else
                {
                    <option value="price_desc">Цена: висока към ниска</option>
                }

                @if (currentSort == "name_asc")
                {
                    <option value="name_asc" selected>Име: A-Z</option>
                }
                else
                {
                    <option value="name_asc">Име: A-Z</option>
                }

                @if (currentSort == "oldest")
                {
                    <option value="oldest" selected>Най-стари</option>
                }
                else
                {
                    <option value="oldest">Най-стари</option>
                }
            </select>

            <button type="submit" class="filter-btn">Приложи</button>
            <a href="/Shop" class="clear-btn">Изчисти</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="no-products-message">
            <h3>Няма намерени продукти</h3>
            <p>Опитай с друга ключова дума или избери различна категория.</p>
        </div>
    }
    else
    {
        <div class="product-grid">
            @foreach (var item in Model)
            {
                <div class="product-card" onclick="goToDetails(@item.Id)">
                    <img src="@item.ImageUrl" alt="@item.Name" class="product-image" />

                    <h3 class="product-name">
                        <a href="/Shop/Details/@item.Id" onclick="stopHere(event)">@item.Name</a>
                    </h3>

                    @if (!string.IsNullOrWhiteSpace(item.Category))
                    {
                        <p class="product-category">✨ @item.Category</p>
                    }

                    <p class="product-description">@item.Description</p>
                    <p class="product-frequency">🧠 @item.FrequencyInfo</p>

                    <audio controls class="product-audio" onclick="stopHere(event)">
                        <source src="@item.SoundUrl" type="audio/mp3" />
                        Вашият браузър не поддържа аудио елемента.
                    </audio>

                    <div class="product-footer" onclick="stopHere(event)">
                        <span class="product-price">@item.Price.ToString("F2") €</span>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <button class="btn-buy" type="button" onclick="addToCart(@item.Id); stopHere(event);">Добави в кошницата</button>
                        }
                        else
                        {
                            <a href="/Auth/Login" class="btn-login-required">🔒 Влез, за да добавиш</a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        function goToDetails(id) {
            window.location.href = `/Shop/Details/${id}`;
        }

        function stopHere(e) {
            if (e && e.stopPropagation) e.stopPropagation();
        }

        function addToCart(id) {
            fetch('/Cart/AddToCart', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: `id=${encodeURIComponent(id)}`,
                credentials: 'include'
            })
                .then(response => response.json())
                .then(data => {
                    if (data && data.success) {
                        showCartMessage();

                        const badge = document.querySelector('.cart-badge');
                        if (badge && typeof data.count === 'number') {
                            badge.textContent = data.count;
                            badge.classList.add('animate');
                            setTimeout(() => badge.classList.remove('animate'), 400);
                        }
                    } else {
                        alert('⚠️ Възникна проблем при добавянето в кошницата.');
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert('⚠️ Грешка при обработката на заявката.');
                });
        }

        function showCartMessage() {
            const msg = document.getElementById('cartMessage');
            msg.style.display = 'block';
            msg.style.opacity = 1;
            setTimeout(() => {
                msg.style.opacity = 0;
                setTimeout(() => msg.style.display = 'none', 400);
            }, 1000);
        }
    </script>
}

<style>
    .shop-container {
        color: #fff;
        padding: 3rem 1rem;
        text-align: center;
        font-family: 'Inter', sans-serif;
    }

    .shop-title {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 0.5rem;
        color: #fff;
    }

    .shop-subtitle {
        font-size: 1.1rem;
        opacity: 0.8;
        margin-bottom: 2rem;
    }

    .shop-filters {
        max-width: 950px;
        margin: 0 auto 2.5rem auto;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
    }

    .search-box,
    .filter-box {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        justify-content: center;
        align-items: center;
        width: 100%;
    }

    .search-input,
    .category-select {
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 0.9rem;
        padding: 0.8rem 1rem;
        min-width: 260px;
        outline: none;
        transition: all 0.3s ease;
        backdrop-filter: blur(6px);
    }

    .search-input {
        width: 100%;
        max-width: 420px;
    }

        .search-input::placeholder {
            color: rgba(255, 255, 255, 0.6);
        }

        .search-input:focus,
        .category-select:focus {
            border-color: #ff69b4;
            box-shadow: 0 0 12px rgba(255, 105, 180, 0.25);
        }

    .category-select option {
        color: #000;
    }

    .search-btn,
    .filter-btn,
    .clear-btn {
        background: rgba(255, 105, 180, 0.18);
        color: #fff;
        border: 1px solid rgba(255, 105, 180, 0.35);
        border-radius: 0.8rem;
        padding: 0.8rem 1.2rem;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .search-btn:hover,
        .filter-btn:hover,
        .clear-btn:hover {
            background: #ff69b4;
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(255, 105, 180, 0.25);
        }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
        gap: 2rem;
        justify-items: center;
    }

    .product-card {
        background: rgba(0, 0, 0, 0.3);
        border-radius: 1.2rem;
        padding: 1.5rem;
        width: 100%;
        max-width: 300px;
        transition: all 0.3s ease;
        box-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 0 25px rgba(255, 105, 180, 0.3);
        }

    .product-image {
        width: 100%;
        border-radius: 1rem;
        margin-bottom: 1rem;
    }

    .product-name {
        font-weight: 700;
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
    }

        .product-name a {
            color: inherit;
            text-decoration: none;
        }

    .product-category {
        font-size: 0.85rem;
        color: #ffc8ea;
        margin-bottom: 0.5rem;
        font-weight: 600;
    }

    .product-description {
        font-size: 0.9rem;
        opacity: 0.9;
        min-height: 60px;
    }

    .product-frequency {
        font-size: 0.85rem;
        color: #f9b4f4;
        margin-top: 0.3rem;
    }

    .product-audio {
        width: 100%;
        margin-top: 1rem;
        margin-bottom: 1rem;
        filter: drop-shadow(0 0 4px rgba(255,105,180,0.2));
    }

    .product-footer {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .product-price {
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.5rem;
    }

    .btn-buy {
        background: #ff69b4;
        border: none;
        color: #fff;
        font-weight: 600;
        padding: 0.5rem 1rem;
        border-radius: 0.7rem;
        cursor: pointer;
        transition: background 0.3s ease, transform 0.2s ease;
    }

        .btn-buy:hover {
            background: #ff85c0;
            transform: scale(1.05);
        }

    .btn-login-required {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
        border-radius: 0.5rem;
        padding: 0.5rem 1rem;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s ease;
    }

        .btn-login-required:hover {
            background: #ff69b4;
            color: #fff;
        }

    .no-products-message {
        max-width: 600px;
        margin: 2rem auto 0 auto;
        padding: 2rem;
        border-radius: 1.2rem;
        background: rgba(255, 255, 255, 0.06);
        box-shadow: 0 0 18px rgba(255, 105, 180, 0.12);
        backdrop-filter: blur(6px);
    }

        .no-products-message h3 {
            margin-bottom: 0.5rem;
            color: #ffd3ec;
        }

        .no-products-message p {
            opacity: 0.85;
        }

    .cart-message {
        position: fixed;
        top: 90px;
        right: 20px;
        background: #ff69b4;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        box-shadow: 0 0 10px rgba(255, 105, 180, 0.4);
        transition: opacity 0.4s ease;
        z-index: 1000;
    }

    @@media (max-width: 768px) {
        .shop-title {
            font-size: 2rem;
        }

        .search-input,
        .category-select {
            width: 100%;
            min-width: unset;
        }

        .search-btn,
        .filter-btn,
        .clear-btn {
            width: 100%;
            max-width: 420px;
        }
    }
</style>